{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "gdb-debug",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/bin/micro.exe", // Путь к вашему исполняемому файлу
            "args": [
                "./test.micro",
                "-o",
                "./test.bin"
            ],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "environment": [],
            "externalConsole": false,
            "MIMode": "gdb",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ],
            "preLaunchTask": "C/C++: gcc.exe сборка активного файла" // Убедитесь, что у вас есть задача сборки
        }
    ]
}